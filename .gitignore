## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## This list is a combination of Microsoft's recommended .gitignore files
## for ASP.NET Core and Visual Studio.

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio files
.vs/
*.user
*.userosscache
*.sln.docstates

# User-specific files
*.suo
*.user
*.userosscache
*.sln.docstates
*.userprefs

# Mono auto generated files
mono_crash.*

# [Vv]isual [Ss]tudio [Cc]ode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# ASP.NET Core
ASPNETCORE_ENVIRONMENT

# nUnit
/*.nnDB

# Rider
.idea/
*.sln.iml

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Built symbols
*.pdb
*.opendb
*.tlog

# Output of dotnet publish
[Pp]ublish/

# Windows image detail files
Thumbs.db
ehthumbs.db
Desktop.ini

# Folder config file
*.swp
*.bak
*~

# NuGet Packages
*.nupkg
# The packages folder can be ignored because of Package Restore
**/[Pp]ackages/*
# except build/, which is used as an MSBuild target.
!**/[Pp]ackages/build/
# Uncomment if using NuGet Soft Links to tie project root to a local restore folder
# .nuget/

# Object files
*.obj

# Backup & temp files from dotnet CLI
*.swp
*~
# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Icon?
ehthumbs.db
Thumbs.db
