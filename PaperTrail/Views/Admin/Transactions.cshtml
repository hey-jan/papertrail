@model IEnumerable<PaperTrail.Models.Order>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Manage Transactions";
}

<h2 class="fw-bold mb-4">Manage Transactions</h2>

<div class="card border-0 shadow-sm overflow-hidden">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-light">
                <tr>
                    <th class="ps-4">Order #</th>
                    <th>Customer</th>
                    <th>Date</th>
                    <th>Total</th>
                    <th>Status</th>
                    <th class="text-end pe-4">Update Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4 fw-bold">#@item.OrderNumber</td>
                        <td>
                            <div>@item.User?.FullName</div>
                            <small class="text-muted">@item.User?.Email</small>
                        </td>
                        <td>@item.OrderDate.ToString("MMM dd, yyyy")</td>
                        <td class="fw-bold">@item.TotalAmount.ToPeso()</td>
                        <td>
                            @switch (item.Status)
                            {
                                case PaperTrail.Models.OrderStatus.Pending:
                                    <span class="badge bg-warning text-dark">Pending</span>
                                    break;
                                case PaperTrail.Models.OrderStatus.Paid:
                                    <span class="badge bg-success">Paid</span>
                                    break;
                                case PaperTrail.Models.OrderStatus.Shipped:
                                    <span class="badge bg-info text-dark">Shipped</span>
                                    break;
                                case PaperTrail.Models.OrderStatus.Completed:
                                    <span class="badge bg-primary">Completed</span>
                                    break;
                                default:
                                    <span class="badge bg-secondary">@item.Status</span>
                                    break;
                            }
                        </td>
                        <td class="text-end pe-4">
                            <form asp-action="UpdateOrderStatus" method="post" class="d-inline-block">
                                <input type="hidden" name="id" value="@item.Id" />
                                <select name="status" class="form-select form-select-sm d-inline-block" style="width: auto;" onchange="this.form.submit()">
                                    @foreach (var status in Enum.GetValues(typeof(PaperTrail.Models.OrderStatus)))
                                    {
                                        <option value="@status" selected="@(item.Status.ToString() == status.ToString())">@status</option>
                                    }
                                </select>
                            </form>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center py-5 text-muted">No transactions found.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
