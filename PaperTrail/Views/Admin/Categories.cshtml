@model IEnumerable<PaperTrail.Models.Category>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Manage Categories";
}

<h2 class="fw-bold mb-4">Manage Categories</h2>

<div class="row g-4">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm p-4">
            <h5 class="fw-bold mb-3">Add Category</h5>
            <form asp-action="CreateCategory" method="post">
                <div class="mb-3">
                    <label class="form-label">Category Name</label>
                    <input name="name" class="form-control" placeholder="e.g. Fiction" required />
                </div>
                <button type="submit" class="btn btn-primary w-100">Add Category</button>
            </form>
        </div>
    </div>
    <div class="col-md-8">
        <div class="card border-0 shadow-sm overflow-hidden">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">ID</th>
                        <th>Name</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">@item.Id</td>
                            <td>@item.Name</td>
                            <td class="text-end pe-4">
                                <form asp-action="DeleteCategory" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Delete this category?');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="3" class="text-center py-4 text-muted">No categories found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
