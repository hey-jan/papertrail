@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold">Dashboard Overview</h2>
    <div class="text-muted">@DateTime.Now.ToString("MMMM dd, yyyy")</div>
</div>

<div class="row g-4 mb-5">
    <div class="col-md-3">
        <div class="card stat-card p-4">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="text-muted mb-2 small text-uppercase fw-semibold">Total Customers</h6>
                    <h3 class="fw-bold mb-0">@ViewBag.CustomerCount</h3>
                </div>
                <div class="rounded-3 d-flex align-items-center justify-content-center" style="width: 48px; height: 48px; background-color: rgba(139, 115, 85, 0.1); color: #8B7355;">
                    <i class="bi bi-people fs-4"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card p-4">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="text-muted mb-2 small text-uppercase fw-semibold">Total Books</h6>
                    <h3 class="fw-bold mb-0">@ViewBag.BookCount</h3>
                </div>
                <div class="rounded-3 d-flex align-items-center justify-content-center" style="width: 48px; height: 48px; background-color: rgba(160, 140, 115, 0.1); color: #A08C73;">
                    <i class="bi bi-book fs-4"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card p-4">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="text-muted mb-2 small text-uppercase fw-semibold">Total Orders</h6>
                    <h3 class="fw-bold mb-0">@ViewBag.OrderCount</h3>
                </div>
                <div class="rounded-3 d-flex align-items-center justify-content-center" style="width: 48px; height: 48px; background-color: rgba(188, 172, 149, 0.15); color: #8B7355;">
                    <i class="bi bi-cart fs-4"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card p-4">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="text-muted mb-2 small text-uppercase fw-semibold">Total Sales</h6>
                    <h3 class="fw-bold mb-0">@(((decimal)ViewBag.TotalSales).ToPeso())</h3>
                </div>
                <div class="rounded-3 d-flex align-items-center justify-content-center" style="width: 48px; height: 48px; background-color: rgba(139, 115, 85, 0.2); color: #5D4037;">
                    <i class="bi bi-cash-stack fs-4"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-8">
        <div class="card border-0 shadow-sm p-4 h-100">
            <h5 class="fw-bold mb-4">Sales Analytics (Last 7 Days)</h5>
            <div style="height: 300px; position: relative;">
                <canvas id="salesChart"></canvas>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm p-4 h-100">
            <h5 class="fw-bold mb-4">Recent Orders</h5>
            <div class="list-group list-group-flush">
                @if (ViewBag.RecentOrders != null && ((List<PaperTrail.Models.Order>)ViewBag.RecentOrders).Any())
                {
                    foreach (var order in (List<PaperTrail.Models.Order>)ViewBag.RecentOrders)
                    {
                        <div class="list-group-item px-0 border-0 mb-3">
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <span class="fw-bold text-dark">#@order.Id.ToString("D5")</span>
                                <small class="text-muted">@order.OrderDate.ToString("MMM dd")</small>
                            </div>
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="text-muted small">@order.User?.Email</span>
                                <span class="fw-bold text-primary small">@order.TotalAmount.ToPeso()</span>
                            </div>
                        </div>
                    }
                    <div class="text-center mt-3">
                        <a asp-action="Transactions" class="btn btn-sm btn-link text-decoration-none p-0">View All Transactions</a>
                    </div>
                }
                else
                {
                    <div class="text-center py-5">
                        <p class="text-muted">No recent orders</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const ctx = document.getElementById('salesChart').getContext('2d');
        const labels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.ChartLabels));
        const data = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.ChartData));

        new Chart(ctx, {
            type: 'line',
            data: {
                labels: labels,
                datasets: [{
                    label: 'Daily Sales (PHP)',
                    data: data,
                    borderColor: '#8B7355',
                    backgroundColor: 'rgba(139, 115, 85, 0.1)',
                    borderWidth: 3,
                    fill: true,
                    tension: 0.4,
                    pointRadius: 4,
                    pointBackgroundColor: '#8B7355'
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        display: false
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        grid: {
                            drawBorder: false,
                            color: 'rgba(0, 0, 0, 0.05)'
                        },
                        ticks: {
                            callback: function(value) {
                                return '?' + value.toLocaleString();
                            }
                        }
                    },
                    x: {
                        grid: {
                            display: false
                        }
                    }
                }
            }
        });
    </script>
}
