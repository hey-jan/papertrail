@model PaperTrail.ViewModels.BookViewModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Add New Book";
}

<div class="mb-4">
    <a asp-action="Books" class="text-muted text-decoration-none"><i class="bi bi-arrow-left"></i> Back to List</a>
    <h2 class="fw-bold mt-2">Add New Book</h2>
</div>

<div class="card border-0 shadow-sm p-4">
    <form asp-action="CreateBook" method="post" enctype="multipart/form-data">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        
        <div class="row g-4">
            <div class="col-md-8">
                <div class="mb-3">
                    <label asp-for="Title" class="form-label"></label>
                    <input asp-for="Title" class="form-control" />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Author" class="form-label"></label>
                    <input asp-for="Author" class="form-control" />
                    <span asp-validation-for="Author" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label"></label>
                    <textarea asp-for="Description" class="form-control" rows="5"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>
            </div>
            
            <div class="col-md-4">
                <div class="mb-3">
                    <label asp-for="CategoryId" class="form-label"></label>
                    <select asp-for="CategoryId" asp-items="Model.Categories" class="form-select">
                        <option value="">-- Select Category --</option>
                    </select>
                    <span asp-validation-for="CategoryId" class="text-danger"></span>
                </div>

                <div class="row mb-3">
                    <div class="col-6">
                        <label asp-for="Price" class="form-label"></label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input asp-for="Price" class="form-control" type="number" step="0.01" />
                        </div>
                        <span asp-validation-for="Price" class="text-danger"></span>
                    </div>
                    <div class="col-6">
                        <label asp-for="Stock" class="form-label"></label>
                        <input asp-for="Stock" class="form-control" type="number" />
                        <span asp-validation-for="Stock" class="text-danger"></span>
                    </div>
                </div>

                <div class="mb-4">
                    <label asp-for="ImageFile" class="form-label"></label>
                    <div class="mb-3 text-center border rounded p-3 bg-light">
                        <img id="imagePreview" src="https://via.placeholder.com/150x220?text=No+Image" 
                             class="img-fluid rounded shadow-sm" style="max-height: 220px;">
                    </div>
                    <input asp-for="ImageFile" class="form-control" type="file" accept="image/*" onchange="previewBookImage(this)" />
                    <span asp-validation-for="ImageFile" class="text-danger"></span>
                </div>
            </div>
        </div>

        <div class="mt-4 pt-3 border-top">
            <button type="submit" class="btn btn-primary px-5 py-2">Create Book</button>
            <a asp-action="Books" class="btn btn-light px-5 py-2 ms-2">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function previewBookImage(input) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function (e) {
                    document.getElementById('imagePreview').src = e.target.result;
                }
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}
