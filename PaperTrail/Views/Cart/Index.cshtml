@model IEnumerable<PaperTrail.Models.CartItem>
@{
    ViewData["Title"] = "Shopping Cart";
}

<div class="container py-5">
    <h2 class="fw-bold mb-5">Your Shopping Cart</h2>

    @if (Model.Any())
    {
        <div class="row g-5">
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm overflow-hidden">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th class="ps-4">Product</th>
                                <th>Price</th>
                                <th>Quantity</th>
                                <th>Total</th>
                                <th class="pe-4"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <div class="d-flex align-items-center">
                                            <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "/images/book-placeholder.svg" : item.ImageUrl)" 
                                                 class="rounded me-3" style="width: 60px; height: 90px; object-fit: cover;" referrerpolicy="no-referrer"
                                                 onerror="this.onerror=null;this.src='/images/book-placeholder.svg';">
                                            <div>
                                                <h6 class="fw-bold mb-0">@item.Title</h6>
                                            </div>
                                        </div>
                                    </td>
                                    <td>$@item.Price</td>
                                    <td>
                                        <form asp-action="UpdateQuantity" method="post" class="d-flex align-items-center" style="max-width: 120px;">
                                            <input type="hidden" name="id" value="@item.BookId" />
                                            <input type="number" name="quantity" value="@item.Quantity" 
                                                   class="form-control form-control-sm text-center" min="1" 
                                                   onchange="this.form.submit()" />
                                        </form>
                                    </td>
                                    <td class="fw-bold">$@item.Total</td>
                                    <td class="pe-4 text-end">
                                        <form asp-action="Remove" method="post">
                                            <input type="hidden" name="id" value="@item.BookId" />
                                            <button type="submit" class="btn btn-link text-danger p-0"><i class="bi bi-trash fs-5"></i></button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="mt-4">
                    <a asp-controller="Home" asp-action="Books" class="text-decoration-none text-accent">
                        <i class="bi bi-arrow-left me-2"></i> Continue Shopping
                    </a>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card border-0 shadow-sm p-4 sticky-top" style="top: 100px;">
                    <h5 class="fw-bold mb-4">Order Summary</h5>
                    <div class="d-flex justify-content-between mb-2">
                        <span>Subtotal</span>
                        <span>$@ViewBag.Total</span>
                    </div>
                    <div class="d-flex justify-content-between mb-4">
                        <span>Shipping</span>
                        <span class="text-success">Free</span>
                    </div>
                    <hr>
                    <div class="d-flex justify-content-between mb-4 mt-2">
                        <h5 class="fw-bold">Total</h5>
                        <h5 class="fw-bold">$@ViewBag.Total</h5>
                    </div>
                    <a asp-action="Checkout" class="btn btn-primary btn-lg w-100 py-3 fw-bold">Proceed to Checkout</a>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-cart-x fs-1 text-muted d-block mb-3"></i>
            <h3 class="fw-bold">Your cart is empty</h3>
            <p class="text-muted mb-4">Looks like you haven't added anything to your cart yet.</p>
            <a asp-controller="Home" asp-action="Books" class="btn btn-primary px-5">Start Shopping</a>
        </div>
    }
</div>
