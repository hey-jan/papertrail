@model IEnumerable<PaperTrail.Models.Book>
@using Microsoft.AspNetCore.Identity
@inject UserManager<PaperTrail.Models.ApplicationUser> UserManager

@{
    ViewData["Title"] = "Customer Dashboard";
    var user = await UserManager.GetUserAsync(User);
    var firstName = user?.FirstName ?? User.Identity?.Name?.Split('@')[0];
}

<div class="container mt-4">
    <div class="row mb-5">
        <div class="col-12">
            <h1 class="display-4 fw-bold mb-3">Welcome back, @firstName!</h1>
            <p class="lead text-muted">Here are your personalized recommendations and quick access to your account.</p>
        </div>
    </div>

    <!-- Quick Stats -->
    <div class="row g-4 mb-5 justify-content-center">
        <div class="col-md-5">
            <div class="card text-white h-100 border-0 shadow-sm" style="background-color: #8B7355;">
                <div class="card-body p-4">
                    <h3 class="card-title fw-bold">My Orders</h3>
                    <p class="card-text">Track recent orders and view purchase history.</p>
                    <a asp-controller="Account" asp-action="Orders" class="btn btn-light mt-2 fw-semibold" style="color: #8B7355;">View Orders</a>
                </div>
            </div>
        </div>
        <div class="col-md-5">
            <div class="card text-white h-100 border-0 shadow-sm" style="background-color: #A08C73;">
                <div class="card-body p-4">
                    <h3 class="card-title fw-bold">Wishlist</h3>
                    <p class="card-text">Check out the books you've saved for later.</p>
                    <a href="#" class="btn btn-light mt-2 fw-semibold" style="color: #A08C73;">View Wishlist</a>
                </div>
            </div>
        </div>
    </div>

    <h2 class="fw-bold mb-4">Recommended For You</h2>

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-4 mb-5">
        @foreach (var book in Model)
        {
            <div class="col">
                <div class="card h-100 book-card border-0 shadow-sm">
                    @if (book.IsBestseller)
                    {
                        <div class="position-absolute top-0 end-0 m-2">
                            <span class="badge bg-warning text-dark"><i class="bi bi-star-fill me-1"></i>Bestseller</span>
                        </div>
                    }
                    <img src="@(string.IsNullOrEmpty(book.ImageUrl) ? "/images/placeholder.jpg" : book.ImageUrl)" class="card-img-top book-img p-3" alt="@book.Title">
                    <div class="card-body">
                        <h5 class="card-title text-truncate" title="@book.Title">@book.Title</h5>
                        <p class="text-muted mb-2">@book.Author</p>

                        <div class="mb-2">
                            @if (book.Categories != null && book.Categories.Any())
                            {
                                @foreach (var cat in book.Categories.Take(2))
                                {
                                    <span class="badge bg-light text-dark fw-normal border me-1">@cat.Name</span>
                                }
                            }
                        </div>

                        <div class="d-flex justify-content-between align-items-center mt-3">
                            <span class="fs-5 fw-bold">@book.Price.ToPeso()</span>
                            <div class="d-flex align-items-center">
                                <i class="bi bi-star-fill text-warning me-1"></i>
                                <span>@book.Rating</span>
                            </div>
                        </div>
                    </div>
                    <div class="card-footer bg-transparent border-0 pb-3 pt-0">
                        <a asp-action="Details" asp-route-id="@book.Id" class="btn btn-outline-primary w-100">View Details</a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>