@model IEnumerable<PaperTrail.Models.Book>
@{
    ViewData["Title"] = "Home Page";
    var categories = ViewBag.Categories as IEnumerable<PaperTrail.Models.Category>;
}

<section class="hero">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6">
                <h1 class="display-3 mb-4">Discover Your Next Favorite Story</h1>
                <p class="lead mb-5">Explore our curated collection of literary masterpieces, from timeless classics to modern bestsellers.</p>
                <div class="d-flex">
                    <a asp-action="Books" class="btn btn-primary btn-lg px-4 me-3">Shop Now</a>
                    <a href="#categories" class="btn btn-outline-secondary btn-lg px-4">Browse Categories</a>
                </div>
            </div>
            <div class="col-lg-6 d-none d-lg-block text-center">
                <img src="https://images.unsplash.com/photo-1524995997946-a1c2e315a42f?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80" 
                     alt="Bookshelf" class="img-fluid rounded-3 shadow-lg" style="max-height: 450px;">
            </div>
        </div>
    </div>
</section>

<section class="featured-books py-5">
    <div class="container">
        <div class="d-flex justify-content-between align-items-end mb-4">
            <h2 class="section-title mb-0 ms-0 text-start">Newly Arrived</h2>
            <a asp-action="Books" class="text-accent text-decoration-none fw-bold">View All <i class="bi bi-arrow-right"></i></a>
        </div>
        <div class="row g-4">
            @foreach (var book in Model)
            {
                <div class="col-sm-6 col-md-4 col-lg-3">
                    <div class="book-card">
                        <a asp-action="Details" asp-route-id="@book.Id">
                            <img src="@(string.IsNullOrEmpty(book.ImageUrl) ? "/images/book-placeholder.svg" : book.ImageUrl)" 
                                 alt="@book.Title" referrerpolicy="no-referrer"
                                 onerror="this.onerror=null;this.src='/images/book-placeholder.svg';">
                        </a>
                        <div class="book-card-body">
                            <a asp-action="Details" asp-route-id="@book.Id" class="text-decoration-none">
                                <h5 class="book-title">@book.Title</h5>
                            </a>
                            <p class="book-author">@book.Author</p>
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="book-price">@book.Price.ToPeso()</span>
                                <form asp-controller="Cart" asp-action="AddToCart" method="post">
                                    <input type="hidden" name="id" value="@book.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-primary rounded-circle @(book.Stock == 0 ? "disabled" : "")"><i class="bi bi-plus-lg"></i></button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
            @if (!Model.Any())
            {
                <div class="col-12 text-center py-5">
                    <p class="text-muted">No books available yet. Check back soon!</p>
                </div>
            }
        </div>
    </div>
</section>

<section id="categories" class="categories py-5 bg-light">
    <div class="container">
        <h2 class="section-title">Shop by Category</h2>
        <div class="row g-4 text-center">
            @if (categories != null)
            {
                foreach (var cat in categories)
                {
                    <div class="col-6 col-md-3">
                        <a asp-action="Books" asp-route-category="@cat.Name" class="text-decoration-none text-dark">
                            <div class="p-4 bg-white rounded shadow-sm category-hover">
                                <i class="bi bi-journal-text fs-1 text-accent mb-3 d-block"></i>
                                <h5>@cat.Name</h5>
                            </div>
                        </a>
                    </div>
                }
            }
        </div>
    </div>
</section>

<style>
    .category-hover {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .category-hover:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 24px rgba(0,0,0,0.1);
    }
</style>
